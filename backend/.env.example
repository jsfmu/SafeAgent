ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# ── Redis ─────────────────────────────────────────────────────────────────────
# Option 1 (recommended for Railway/serverless): Upstash REST — no TCP, works everywhere
# Get from console.upstash.com → Redis → REST API
UPSTASH_REDIS_REST_URL=https://YOUR_DB.upstash.io
UPSTASH_REDIS_REST_TOKEN=YOUR_UPSTASH_TOKEN_HERE

# Option 2: Standard Redis URL (used as fallback if Upstash vars not set)
# Format: rediss://:PASSWORD@HOST.redislabs.com:PORT
REDIS_URL=rediss://:YOUR_REDIS_PASSWORD@YOUR_HOST.redislabs.com:PORT

# ── App ───────────────────────────────────────────────────────────────────────
SAFETY_GATE_URL=http://localhost:8000/gate/check

# CORS — add your Vercel frontend URL after deploying
# Example: https://safeagent.vercel.app,http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

AUTO_FIX_ENABLED=true

# ── Deepgram ──────────────────────────────────────────────────────────────────
# Get from console.deepgram.com → API Keys
DEEPGRAM_API_KEY=YOUR_DEEPGRAM_KEY_HERE

# ── ASI:One / AgentVerse ──────────────────────────────────────────────────────
# Get from agentverse.ai → API Keys  (falls back to mock data if not set)
AGENTVERSE_API_KEY=YOUR_AGENTVERSE_KEY_HERE
