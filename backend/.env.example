ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# Redis Cloud — get from Redis Cloud console → Database → Connect
# Format: rediss://:PASSWORD@HOST.redislabs.com:PORT  (double-s = TLS)
REDIS_URL=rediss://:YOUR_REDIS_PASSWORD@YOUR_HOST.redislabs.com:PORT

# Gate is part of this backend (same service, same port)
SAFETY_GATE_URL=http://localhost:8000/gate/check

# CORS — add your Vercel frontend URL when deploying
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

AUTO_FIX_ENABLED=true

# Deepgram — get from console.deepgram.com → API Keys
# Used for: TTS readout of safety warnings (POST /voice/tts)
#           Keyword detection on agent description (POST /voice/keywords)
DEEPGRAM_API_KEY=YOUR_DEEPGRAM_KEY_HERE

# ASI:One / AgentVerse — get from agentverse.ai → API Keys
# Used for: querying existing certified agents before scaffold (POST /asi/discover)
# Falls back to mock data if not set
AGENTVERSE_API_KEY=YOUR_AGENTVERSE_KEY_HERE
