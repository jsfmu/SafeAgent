# Joseph's backend (FastAPI on Railway or localhost)
VITE_API_URL=http://localhost:8000

# Gate service is merged into the backend — same URL as VITE_API_URL
# Override only if deployed separately
VITE_GATE_URL=http://localhost:8000

# Set to false to use real backend APIs
VITE_USE_MOCK=true

# Deepgram — get from console.deepgram.com → API Keys
# Used for: live STT mic input on the input screen, voice HITL on the flag modal
# STT connects directly browser → Deepgram WebSocket (key exposed to browser — use a restricted key)
VITE_DEEPGRAM_API_KEY=YOUR_DEEPGRAM_KEY_HERE

# Arize Phoenix — local or hosted. Defaults to localhost:6006
VITE_PHOENIX_URL=localhost:6006
