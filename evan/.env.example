# ── Redis Cloud ───────────────────────────────────────────────────────────────
# Get this from: Redis Cloud console → Database → Connect → Copy Public Endpoint
# Format:  rediss://:PASSWORD@HOST:PORT
# Note: 'rediss' (double-s) = TLS — required for Redis Cloud
REDIS_URL=rediss://:YOUR_REDIS_PASSWORD@YOUR_HOST.redislabs.com:PORT

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# ── CORS — Vercel frontend URLs ───────────────────────────────────────────────
# Comma-separated list. Add your Vercel prod URL + any preview URLs.
# All *.vercel.app URLs are auto-allowed by regex — add localhost for local dev.
ALLOWED_ORIGINS=http://localhost:3000,https://YOUR-APP.vercel.app
